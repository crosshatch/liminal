{
  "name": "effect-workerd",
  "version": "0.0.4",
  "description": "Effect x Cloudflare",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "effect-workerd"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts",
    "./platform": "./platform/index.ts",
    "./observability": "./observability/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./platform": "./dist/platform/index.js",
      "./observability": "./dist/observability/index.js"
    }
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/sql-d1": "catalog:",
    "effect": "catalog:",
    "liminal-util": "workspace:*"
  }
}
