{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tictactoe",
  "main": "./main.ts",
  "compatibility_date": "2026-02-05",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "keep_vars": true,
  "observability": {
    "enabled": true,
  },
  "placement": {
    "mode": "smart",
  },
  "vars": {
    "DEV": true,
  },
  "worker_loaders": [{ "binding": "LOADER" }],
}
