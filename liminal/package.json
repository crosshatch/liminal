{
  "name": "liminal",
  "version": "0.17.14",
  "description": "Effect x Actors",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "liminal"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts",
    "./browser": "./browser/index.ts",
    "./experimental": "./experimental/index.ts",
    "./workerd": "./workerd/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./browser": "./dist/browser/index.js",
      "./experimental": "./dist/experimental/index.js",
      "./workerd": "./dist/workerd/index.js",
      "./package.json": "./package.json"
    }
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/sql-d1": "catalog:",
    "effect": "catalog:",
    "effect-workerd": "workspace:*",
    "liminal-util": "workspace:*"
  }
}
