{
  "name": "liminal-root",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "node ./konfik/main.ts clean --ignore '**/repos'",
    "dev": "pnpm i && PNPM_CONFIG_VERIFY_DEPS_BEFORE_RUN=false turbo run dev //#watch //#aliases",
    "aliases": "caddy run --config ./Caddyfile",
    "konfik": "node ./konfik/main.ts",
    "sync-repos": "pnpm konfik sync-repos",
    "destroy": "alchemy destroy",
    "plan": "alchemy plan",
    "prepare": "ts-patch install -s",
    "test": "vitest run",
    "watch": "tsc -b -w"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/expect": "catalog:",
    "@vitest/web-worker": "catalog:",
    "alchemy": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "happy-dom": "catalog:",
    "liminal-util": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "ts-patch": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.10.0"
}
