{
  "name": "liminal",
  "version": "0.17.19",
  "description": "Effect x Actors",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "liminal"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "workerd": "./index.ts",
      "browser": "./index.non-workerd.ts",
      "node": "./index.non-workerd.ts",
      "default": "./index.ts"
    },
    "./*": "./*.ts",
    "./experimental": "./experimental/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "workerd": "./dist/index.js",
        "browser": "./dist/index.non-workerd.js",
        "node": "./dist/index.non-workerd.js",
        "default": "./dist/index.js"
      },
      "./*": "./dist/*.js",
      "./experimental": "./dist/experimental/index.js",
      "./package.json": "./package.json"
    }
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/sql-d1": "catalog:",
    "effect": "catalog:",
    "effect-workerd": "workspace:*",
    "liminal-util": "workspace:*"
  }
}
