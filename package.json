{
  "name": "liminal-root",
  "type": "module",
  "scripts": {
    "build": "tsc -b && turbo run build",
    "changeset": "changeset",
    "check": "tsc -b",
    "clean": "node ./repos/konfik/main.ts clean --ignore '**/repos/**/*'",
    "dev": "turbo run dev //#watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "ts-patch install -s",
    "test": "vitest run",
    "watch": "tsc -b -w"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/expect": "catalog:",
    "@vitest/web-worker": "catalog:",
    "effect": "catalog:",
    "happy-dom": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "ts-patch": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
