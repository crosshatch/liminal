{
  "name": "liminal",
  "version": "0.17.10",
  "description": "Actors x Effects",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "liminal"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "liminal": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
