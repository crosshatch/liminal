{
  "name": "liminal",
  "version": "0.17.11",
  "description": "Effect x Actors",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "liminal"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./browser": {
      "types": "./browser/index.ts",
      "default": "./dist/browser/index.js"
    },
    "./experimental": {
      "types": "./experimental/index.ts",
      "default": "./dist/experimental/index.js"
    },
    "./workerd": {
      "types": "./workerd/index.ts",
      "default": "./dist/workerd/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/sql-d1": "catalog:",
    "effect": "catalog:",
    "effect-workerd": "workspace:*",
    "liminal-util": "workspace:*"
  }
}
