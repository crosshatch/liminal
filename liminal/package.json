{
  "name": "liminal",
  "version": "0.17.11",
  "description": "Effect x Cloudflare",
  "bugs": {
    "url": "https://github.com/crosshatch/liminal/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/liminal.git",
    "directory": "liminal"
  },
  "bin": {
    "liminal": "./dist/main.js"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./actor": {
      "types": "./actor/index.ts",
      "default": "./dist/actor/index.js"
    },
    "./experimental": {
      "types": "./experimental/index.ts",
      "default": "./dist/experimental/index.js"
    },
    "./platform": {
      "types": "./platform/index.ts",
      "default": "./dist/platform/index.js"
    },
    "./util/*": {
      "types": "./util/*.ts",
      "default": "./dist/util/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/sql-d1": "catalog:",
    "effect": "catalog:"
  }
}
